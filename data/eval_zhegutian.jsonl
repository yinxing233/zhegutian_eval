{"task_id": "logic_03_contrast", "L0_surface_prompt": "请写一首《鹧鸪天》，上阕描写繁华闹市，下阕转写山中清冷，形成强烈对比。要求遵循格律，押中华新韵。", "L0_constraints": {"cipai": "鹧鸪天", "rhyme_system": "中华新韵", "rhyme_bu": null, "theme": "闹市与山林对比", "required_words": [], "pingze_strictness": "strict"}, "L0_difficulty_axes": {"constraint_density": "medium", "semantic_distance": "high", "style_conflict": "high", "emotion_shift": "high", "imagery_coupling": "medium"}, "L0_task_tags": ["对比结构", "情绪转折", "双场景"], "L1_expected_failure_modes": ["F_identity", "F_emotional", "F_imagery", "structure_collapse"], "L2_latent_tensions": ["上下阕场景极异，过片处是结构脆弱点——模型可能在此处发生身份漂移或情绪断裂", "闹市词汇与山林词汇在语义空间距离大，过渡生硬会导致全词割裂为两首不相关的半阙", "情绪从喧嚣到冷清的转折需要铺垫，否则变成单纯并列而非对比"], "prompt_version": "v1"}
{"task_id": "modern_04_topic", "L0_surface_prompt": "请尝试用《鹧鸪天》的格律描写“程序员深夜加班”的场景。要求不得出韵，且意境要与词牌相契合。", "L0_constraints": {"cipai": "鹧鸪天", "rhyme_system": "中华新韵", "rhyme_bu": null, "theme": "程序员深夜加班", "required_words": [], "pingze_strictness": "strict"}, "L0_difficulty_axes": {"constraint_density": "medium", "semantic_distance": "high", "style_conflict": "high", "emotion_shift": "low", "imagery_coupling": "low"}, "L0_task_tags": ["现代主题", "古典形式", "语义跨度"], "L1_expected_failure_modes": ["F_identity", "modern_word_leak", "template_parroting"], "L2_latent_tensions": ["现代科技词汇（屏幕、代码、键盘）与词牌传统语境的根本冲突——这是词牌语义边界的高压测试", "模型可能因语义距离过大而退化为两种策略：强行古典化导致主题模糊，或直白现代词导致风格崩塌", "'意境与词牌契合'的要求形成隐性约束：既不能写成打油诗，也不能写成完全去情境的古董词"], "prompt_version": "v1"}
{"task_id": "stress_05_rhyme", "L0_surface_prompt": "请写一首《鹧鸪天》，主题为咏梅，但限定必须押“十一庚”韵（如：惊、青、屏）。要求严格符合平仄。", "L0_constraints": {"cipai": "鹧鸪天", "rhyme_system": "中华新韵", "rhyme_bu": "十一庚", "theme": "咏梅", "required_words": [], "pingze_strictness": "strict"}, "L0_difficulty_axes": {"constraint_density": "high", "semantic_distance": "low", "style_conflict": "low", "emotion_shift": "low", "imagery_coupling": "medium"}, "L0_task_tags": ["咏梅", "限定韵部", "强约束", "测试组"], "L1_expected_failure_modes": ["constraint_overload", "empty_output", "template_parroting", "F_imagery", "rhyme_forced"], "L2_latent_tensions": ["韵部限定（十一庚）大幅压缩可用韵脚词汇空间，咏梅常用字（如'清''冰''影'）可能不在该韵部内，形成韵脚与主题的词汇争夺", "平仄严格约束叠加韵部限定，可能导致模型在局部位置被迫选择语义不契合但声调合规的词，从而触发意象失联", "高约束密度下，模型可能因无法在 token 预算内找到合法解而直接放弃生成（场完全塌缩至零）"], "prompt_version": "v1"}