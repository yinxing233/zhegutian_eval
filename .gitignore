# =================================================================
# 1. Python 运行与构建产物 (保持代码库整洁)
# =================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
wheels/
*.egg-info/
.installed.cfg
*.manifest
*.spec

# =================================================================
# 2. 虚拟环境与工具配置 (环境隔离)
# =================================================================
.venv/
venv/
ENV/
.python-version
# 注意：不忽略 uv.lock 和 pyproject.toml，以确保依赖一致性

# =================================================================
# 3. 项目特定忽略
# =================================================================
# 自动化工具与文档草稿
.roo/
docs/
plans/

# 数据与评估产物
# 如果你的 data/ 文件夹内包含不希望上传的大型数据集或生成的 jsonl，建议取消下一行注释
# data/*.jsonl
*.log

# =================================================================
# 4. 编辑器与操作系统 (个人偏好文件)
# =================================================================
.vscode/
.idea/
*.swp
*.bak
.DS_Store
Thumbs.db

# =================================================================
# 5. 安全性 (防止密钥泄露)
# =================================================================
.env
.env.*