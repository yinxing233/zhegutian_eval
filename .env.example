# ==========================================
# LLM Provider & Model
# ==========================================

# 生成阶段使用的 LLM 提供商（gemini / deepseek / glm）
LLM_PROVIDER=deepseek

# 评测阶段使用的 LLM 提供商（gemini / deepseek / glm）
EVAL_PROVIDER=deepseek

# 评测阶段使用的具体模型名称
EVAL_MODEL=deepseek-v4-flash

# ==========================================
# API Keys & Models
# 按你选择的 Provider 填写对应配置即可，未使用的可留空
# ==========================================

# DeepSeek API 密钥
DEEPSEEK_API_KEY=your_api_key_here
# DeepSeek 模型名称
DEEPSEEK_MODEL=deepseek-v4-flash

# Gemini API 密钥
GEMINI_API_KEY=your_api_key_here
# Gemini 模型名称
GEMINI_MODEL=gemini-3-flash-preview

# GLM（智谱）API 密钥
GLM_API_KEY=your_api_key_here
# GLM 模型名称
GLM_MODEL=glm-4.5-air

# ==========================================
# Generation Parameters（生成参数）
# ==========================================

# 生成温度，控制输出随机性，越高越有创意（0.0 ~ 1.0）
GENERATION_TEMPERATURE=0.9

# 生成最大输出 Token 数
GENERATION_MAX_OUTPUT_TOKENS=2048

# Top-P 采样，核采样概率阈值（0.0 ~ 1.0）
GENERATION_TOP_P=0.95

# Top-K 采样，仅从概率最高的 K 个 Token 中选取
GENERATION_TOP_K=40

# ==========================================
# Rate Limiting（速率限制）
# ==========================================

# API 调用间隔，单位：秒，避免触发频率限制
API_DELAY_SECONDS=1

# ==========================================
# Evaluation Thresholds（评测阈值）
# ==========================================

# 触发语义评测的最低平仄得分
MIN_PINGZE_FOR_SEMANTIC=20

# 结构韵律匹配阈值比例
STRUCTURE_RHYME_THRESHOLD_RATIO=0.8